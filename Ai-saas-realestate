        let PROPERTIES = [ /* same as before */ ]
        
        // Live buyer feed simulation
        function startLiveBuyerFeed() {
            const feed = document.getElementById('live-buyer-feed')
            const buyers = [
                { name: "Mr. Bilal Ahmed", city: "Lahore", match: "99%", time: "12s ago" },
                { name: "Engr. Sara Khan", city: "Islamabad", match: "97%", time: "38s ago" },
                { name: "Dr. Hassan Raza", city: "Faisalabad", match: "94%", time: "1m ago" },
                { name: "Family of 6", city: "Gujranwala", match: "96%", time: "2m ago" }
            ]
            
            setInterval(() => {
                if (feed.children.length > 5) feed.removeChild(feed.children[0])
                
                const randomBuyer = buyers[Math.floor(Math.random() * buyers.length)]
                const div = document.createElement('div')
                div.className = "glass rounded-3xl p-4 flex items-center justify-between text-sm"
                div.innerHTML = `
                    <div class="flex items-center">
                        <div class="w-8 h-8 bg-white/10 rounded-2xl flex items-center justify-center text-xl mr-3">👤</div>
                        <div>
                            <div>${randomBuyer.name}</div>
                            <div class="text-xs text-white/60">${randomBuyer.city}</div>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-[#00f7d8] font-bold">${randomBuyer.match} MATCH</div>
                        <div class="text-xs">${randomBuyer.time}</div>
                    </div>
                `
                feed.appendChild(div)
            }, 1400)
        }
        
        // Live buyer matching grid
        function startBuyerMatchingEngine() {
            const grid = document.getElementById('buyer-matching-grid')
            const sampleBuyers = [
                { name: "Bilal Ahmed", score: 99, offer: "4.12 CR", location: "Lahore" },
                { name: "Sara Khan", score: 97, offer: "3.98 CR", location: "Islamabad" },
                { name: "Hassan Raza", score: 95, offer: "4.05 CR", location: "Faisalabad" }
            ]
            
            sampleBuyers.forEach(b => {
                const card = document.createElement('div')
                card.className = "glass rounded-3xl p-8 text-center cursor-pointer hover:ring-4 hover:ring-[#00f7d8]/50"
                card.innerHTML = `
                    <div class="text-6xl mb-6">👤</div>
                    <div class="text-3xl font-semibold">${b.name}</div>
                    <div class="text-[#00f7d8] text-xl">AI MATCH: ${b.score}%</div>
                    <div class="text-5xl font-bold text-white mt-6">₹${b.offer}</div>
                    <div class="text-xs mt-2">${b.location} • Ready to buy today</div>
                    <div class="mt-8 text-sm bg-white/10 py-4 rounded-3xl">AI is negotiating with this buyer RIGHT NOW</div>
                `
                card.onclick = () => launchFullAISellProcess(b)
                grid.appendChild(card)
            })
        }
        
